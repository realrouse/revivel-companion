{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReviveL Companion",
  "version": "0.1.2",
  "identifier": "com.revivel.companion",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ReviveL Companion",
        "width": 880,
        "height": 620,
        "resizable": true,
        "minWidth": 780,
        "minHeight": 520,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["lbry"]
      }
    },
    "single-instance": null
  }
}
